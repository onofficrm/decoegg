# 이 호스팅은 .html 요청이 PHP로 넘어가 MySQL 대기(504)에 걸립니다.
# 정적 랜딩은 .txt + text/html 로 제공합니다.
DirectoryIndex css/landing.txt index.php

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^$ css/landing.txt [L]
</IfModule>

<IfModule mod_headers.c>
  <Files "landing.txt">
    Header set Content-Type "text/html; charset=utf-8"
  </Files>
</IfModule>

<IfModule mod_mime.c>
  <Files "landing.txt">
    ForceType text/html
  </Files>
</IfModule>
